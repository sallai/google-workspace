#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "google-auth-oauthlib>=1.0.0",
#     "google-auth-httplib2>=0.1.0",
#     "google-api-python-client>=2.0.0",
# ]
# ///

from __future__ import annotations

import argparse
import configparser
import datetime as dt
import json
import os
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
from typing import Any

from google.auth.exceptions import RefreshError
from google.auth.transport.requests import Request
from google.oauth2.credentials import Credentials
from google_auth_oauthlib.flow import InstalledAppFlow
from googleapiclient.discovery import build
from googleapiclient.errors import HttpError


APP_DIR = Path.home() / ".google-workspace"
GOOGLE_WORKSPACE_ENV_FILES = [
    APP_DIR / "env",
    APP_DIR / "google-workspace.env",
    APP_DIR / ".env",
]
LEGACY_RC_FILE = Path.home() / ".googleworkspacerc"
DEFAULT_CLIENT_SECRET_FILE = APP_DIR / "client_secret.json"
DEFAULT_TOKEN_FILE = APP_DIR / "token.json"

SCOPES = [
    "https://www.googleapis.com/auth/calendar.readonly",
    "https://www.googleapis.com/auth/documents.readonly",
    "https://www.googleapis.com/auth/drive.readonly",
]
AUTH_SETUP_STATUSES = {401, 403}
AUTH_SETUP_REASONS = {
    "access_denied",
    "deleted_client",
    "invalid_client",
    "invalid_grant",
    "invalid_request",
    "invalid_scope",
    "unauthorized_client",
}
API_BASES = {
    "calendar": "https://www.googleapis.com/calendar/v3",
    "docs": "https://docs.googleapis.com/v1",
    "drive": "https://www.googleapis.com/drive/v3",
    "oauth2": "https://oauth2.googleapis.com",
}
EXIT_RUNTIME = 1
EXIT_USAGE = 2
EXIT_AUTH = 3
EXIT_PERMISSION = 4
EXIT_DOMAIN = 5
OUTPUT_FORMAT = "human"
STARTED_AT = time.perf_counter()


class GoogleWorkspaceSetupError(RuntimeError):
    pass


class GoogleWorkspaceError(RuntimeError):
    def __init__(self, message: str, status: int | None = None, reason: str | None = None) -> None:
        self.status = status
        self.reason = reason
        super().__init__(message)


class GoogleWorkspaceClient:
    def __init__(self, credentials: Credentials) -> None:
        self.credentials = credentials

    def service(self, name: str, version: str) -> Any:
        return build(name, version, credentials=self.credentials)

    def request(self, method: str, url: str, body: dict[str, Any] | None = None) -> Any:
        self.credentials.refresh(Request()) if self.credentials.expired else None
        payload = None if body is None else json.dumps(body).encode("utf-8")
        request = urllib.request.Request(
            url,
            data=payload,
            method=method,
            headers={
                "Authorization": f"Bearer {self.credentials.token}",
                "Content-Type": "application/json; charset=utf-8",
            },
        )
        try:
            with urllib.request.urlopen(request) as response:
                raw = response.read().decode("utf-8")
        except urllib.error.HTTPError as error:
            raw = error.read().decode("utf-8", errors="replace")
            raise GoogleWorkspaceError(
                f"Google API HTTP {error.code} {error.reason}: {raw}",
                status=error.code,
                reason=raw,
            ) from error
        return json.loads(raw) if raw else {}


def main() -> int:
    global OUTPUT_FORMAT, STARTED_AT
    STARTED_AT = time.perf_counter()
    args = build_parser().parse_args()
    OUTPUT_FORMAT = args.output
    load_env_files([Path(path).expanduser() for path in args.env_file] if args.env_file else GOOGLE_WORKSPACE_ENV_FILES)

    try:
        if args.schema:
            emit_json(build_schema())
            return 0
        if not hasattr(args, "func"):
            build_parser().print_usage(sys.stderr)
            return EXIT_USAGE
        if not getattr(args, "requires_auth", True):
            return args.func(None, args)

        credentials = get_credentials(interactive=False)
        client = GoogleWorkspaceClient(credentials)
        return args.func(client, args)
    except (GoogleWorkspaceSetupError, RefreshError) as error:
        return emit_error("missing_credentials", str(error), EXIT_AUTH, setup_text=build_google_workspace_setup_text())
    except HttpError as error:
        exit_code = EXIT_AUTH if error.status_code in AUTH_SETUP_STATUSES else EXIT_RUNTIME
        return emit_error("google_api_error", f"Google API HTTP {error.status_code}: {error}", exit_code, setup_text=build_google_workspace_setup_text() if error.status_code in AUTH_SETUP_STATUSES else None)
    except GoogleWorkspaceError as error:
        exit_code = EXIT_AUTH if error.status in AUTH_SETUP_STATUSES else EXIT_RUNTIME
        return emit_error("google_api_error", str(error), exit_code, setup_text=build_google_workspace_setup_text() if error.status in AUTH_SETUP_STATUSES else None)
    except (RuntimeError, ValueError, OSError, json.JSONDecodeError) as error:
        return emit_error("runtime_error", str(error), EXIT_RUNTIME)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="google-workspace-cli",
        description=(
            "Single-file Google Workspace CLI using ~/.google-workspace credentials. "
            "Exit codes: 0 success, 1 runtime/API, 2 usage, 3 auth, 4 permission, 5 domain."
        ),
    )
    parser.add_argument(
        "--env-file",
        action="append",
        help="Credential env file to load. Defaults to ~/.google-workspace/env and compatible fallbacks.",
    )
    parser.add_argument("--output", choices=["human", "json"], default="human", help="Output format. JSON mode emits one envelope object.")
    parser.add_argument("--schema", action="store_true", help="Print machine-readable command schema as JSON.")
    subparsers = parser.add_subparsers()

    add_setup_parser(subparsers)
    add_auth_parser(subparsers)
    add_me_parser(subparsers)
    add_config_parser(subparsers)
    add_api_parser(subparsers)
    add_schema_parser(subparsers)
    add_calendar_parser(subparsers)
    add_docs_parser(subparsers)
    add_drive_parser(subparsers)

    return parser


def add_setup_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    parser = subparsers.add_parser("setup", help="Print Google Workspace OAuth setup instructions.")
    output = parser.add_mutually_exclusive_group()
    output.add_argument("--env-only", action="store_true", help="Print only the local credential-file instructions.")
    output.add_argument("--scopes-only", action="store_true", help="Print only the OAuth scope list.")
    output.add_argument("--oauth-note", action="store_true", help="Print notes about OAuth client setup.")
    parser.set_defaults(func=cmd_setup, requires_auth=False)


def add_auth_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    auth = subparsers.add_parser("auth", help="OAuth login and token status helpers.")
    auth_sub = auth.add_subparsers(required=True)

    login = auth_sub.add_parser("login", help="Run browser-based OAuth and store the token locally.")
    login.set_defaults(func=cmd_auth_login, requires_auth=False)

    status = auth_sub.add_parser("status", help="Show token status without printing token contents.")
    status.set_defaults(func=cmd_auth_status, requires_auth=False)


def add_me_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    parser = subparsers.add_parser("me", help="Show token/account information for the active credentials.")
    parser.set_defaults(func=cmd_me)


def add_config_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    parser = subparsers.add_parser("config", help="Show resolved configuration paths without printing secrets.")
    parser.set_defaults(func=cmd_config, requires_auth=False)


def add_api_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    parser = subparsers.add_parser("api", help="Call any authenticated Google REST endpoint.")
    parser.add_argument("method", choices=["GET", "POST", "PATCH", "PUT", "DELETE"])
    parser.add_argument("path", help="Full URL or path under --base, e.g. /files or /calendar/v3/users/me/calendarList.")
    parser.add_argument("--base", choices=sorted(API_BASES), default="drive", help="Base API when path is not a full URL.")
    parser.add_argument("--data", help="JSON request body, @file.json, or - for stdin.")
    parser.add_argument("--query", action="append", default=[], help="Append query params as key=value.")
    parser.set_defaults(func=cmd_api)


def add_schema_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    parser = subparsers.add_parser("schema", help="Print machine-readable command schema.")
    parser.set_defaults(func=cmd_schema, requires_auth=False)


def add_calendar_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    calendar = subparsers.add_parser("calendar", help="Google Calendar read operations.")
    calendar_sub = calendar.add_subparsers(required=True)

    list_events = calendar_sub.add_parser("list-events", help="List calendar events.")
    list_events.add_argument("--calendar-id", default="primary")
    list_events.add_argument("--time-min", help="Start time (ISO 8601). Defaults to now.")
    list_events.add_argument("--time-max", help="End time (ISO 8601).")
    list_events.add_argument("--max-results", type=int, default=50)
    list_events.add_argument("--detailed", action="store_true", help="Include descriptions, locations, attendees, and attachments.")
    list_events.set_defaults(func=cmd_calendar_list_events)

    get_event = calendar_sub.add_parser("get-event", help="Get a specific event.")
    get_event.add_argument("event_id")
    get_event.add_argument("--calendar-id", default="primary")
    get_event.set_defaults(func=cmd_calendar_get_event)


def add_docs_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    docs = subparsers.add_parser("docs", help="Google Docs read operations.")
    docs_sub = docs.add_subparsers(required=True)

    get_content = docs_sub.add_parser("get-content", help="Get document text content.")
    get_content.add_argument("document", help="Google Doc ID or URL.")
    get_content.add_argument("--tab-id", help="Specific tab ID, e.g. t.1f0ke3b6pi4g.")
    get_content.add_argument("--tab-title", help="Specific tab title or title fragment.")
    get_content.add_argument("--output", help="Write content to this local file instead of printing JSON.")
    get_content.set_defaults(func=cmd_docs_get_content)

    list_tabs = docs_sub.add_parser("list-tabs", help="List tabs in a document.")
    list_tabs.add_argument("document", help="Google Doc ID or URL.")
    list_tabs.set_defaults(func=cmd_docs_list_tabs)


def add_drive_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    drive = subparsers.add_parser("drive", help="Google Drive read operations.")
    drive_sub = drive.add_subparsers(required=True)

    search = drive_sub.add_parser("search", help="Search Drive by name, full text, or raw Drive query.")
    search.add_argument("query", help="Plain text or Drive query expression.")
    search.add_argument("--full-text", action="store_true", help="Search file contents instead of names for plain text queries.")
    search.add_argument("--modified-after", metavar="DATE", help="Only files modified after DATE (YYYY-MM-DD or RFC3339).")
    search.add_argument("--mime-type", metavar="TYPE", help="Filter by MIME type.")
    search.add_argument("--max-results", type=int, default=25)
    search.set_defaults(func=cmd_drive_search)


def cmd_setup(_client: GoogleWorkspaceClient | None, args: argparse.Namespace) -> int:
    if args.env_only:
        text = build_google_workspace_env_setup_text().rstrip()
    elif args.scopes_only:
        text = build_google_workspace_scopes_text().rstrip()
    elif args.oauth_note:
        text = build_google_workspace_oauth_note_text().rstrip()
    else:
        text = build_google_workspace_setup_text().rstrip()
    if OUTPUT_FORMAT == "json":
        emit_json({"text": text})
    else:
        print(text, flush=True)
    return 0


def cmd_auth_login(_client: GoogleWorkspaceClient | None, _args: argparse.Namespace) -> int:
    credentials = get_credentials(interactive=True)
    emit_json(token_summary(credentials))
    return 0


def cmd_auth_status(_client: GoogleWorkspaceClient | None, _args: argparse.Namespace) -> int:
    config = load_config()
    token_path = Path(config["token_file"])
    if not token_path.exists():
        emit_json({"token_file": str(token_path), "exists": False, "valid": False})
        return 1
    credentials = Credentials.from_authorized_user_file(str(token_path), SCOPES)
    emit_json({"token_file": str(token_path), "exists": True, **token_summary(credentials)})
    return 0 if credentials.valid else 1


def cmd_me(client: GoogleWorkspaceClient, _args: argparse.Namespace) -> int:
    token = client.credentials.token
    url = f"https://oauth2.googleapis.com/tokeninfo?{urllib.parse.urlencode({'access_token': token})}"
    result = client.request("GET", url)
    emit_json(result)
    return 0


def cmd_config(_client: GoogleWorkspaceClient | None, _args: argparse.Namespace) -> int:
    config = load_config()
    emit_json(
        {
            "env_files": [
                {"path": str(path), "exists": path.exists()} for path in GOOGLE_WORKSPACE_ENV_FILES
            ],
            "legacy_rc_file": {"path": str(LEGACY_RC_FILE), "exists": LEGACY_RC_FILE.exists()},
            "client_secret_file": {
                "path": config["client_secret_file"],
                "exists": Path(config["client_secret_file"]).exists(),
            },
            "token_file": {"path": config["token_file"], "exists": Path(config["token_file"]).exists()},
            "email": config.get("email"),
            "scopes": SCOPES,
        }
    )
    return 0


def cmd_api(client: GoogleWorkspaceClient, args: argparse.Namespace) -> int:
    body = read_json_arg(args.data) if args.data else None
    url = api_url(args.path, args.base, args.query)
    emit_json(client.request(args.method, url, body))
    return 0


def cmd_schema(_client: GoogleWorkspaceClient | None, _args: argparse.Namespace) -> int:
    emit_json(build_schema())
    return 0


def cmd_calendar_list_events(client: GoogleWorkspaceClient, args: argparse.Namespace) -> int:
    service = client.service("calendar", "v3")
    time_min = args.time_min or dt.datetime.now(dt.timezone.utc).isoformat().replace("+00:00", "Z")
    params = {
        "calendarId": args.calendar_id,
        "timeMin": time_min,
        "maxResults": args.max_results,
        "singleEvents": True,
        "orderBy": "startTime",
    }
    if args.time_max:
        params["timeMax"] = args.time_max

    result = service.events().list(**params).execute()
    events = [calendar_event_summary(event, detailed=args.detailed) for event in result.get("items", [])]
    emit_json({"count": len(events), "events": events})
    return 0


def cmd_calendar_get_event(client: GoogleWorkspaceClient, args: argparse.Namespace) -> int:
    service = client.service("calendar", "v3")
    event = service.events().get(calendarId=args.calendar_id, eventId=args.event_id).execute()
    emit_json(calendar_event_summary(event, detailed=True))
    return 0


def cmd_docs_get_content(client: GoogleWorkspaceClient, args: argparse.Namespace) -> int:
    service = client.service("docs", "v1")
    document_id = parse_google_file_id(args.document)
    doc = service.documents().get(documentId=document_id, includeTabsContent=True).execute()
    output = {"documentId": document_id, "title": doc.get("title", ""), "content": document_text(doc, args)}

    if args.output:
        Path(args.output).expanduser().write_text(output["content"], encoding="utf-8")
        print(f"Wrote {args.output}", file=sys.stderr, flush=True)
        if OUTPUT_FORMAT == "json":
            emit_json({"documentId": document_id, "title": doc.get("title", ""), "output": str(Path(args.output).expanduser())})
    else:
        emit_json(output)
    return 0


def cmd_docs_list_tabs(client: GoogleWorkspaceClient, args: argparse.Namespace) -> int:
    service = client.service("docs", "v1")
    document_id = parse_google_file_id(args.document)
    doc = service.documents().get(documentId=document_id, includeTabsContent=True).execute()
    tabs = []
    for tab in doc.get("tabs", []):
        properties = tab.get("tabProperties", {})
        tabs.append(
            {
                "tabId": properties.get("tabId", ""),
                "title": properties.get("title", ""),
                "index": properties.get("index", 0),
            }
        )
    emit_json({"documentId": document_id, "title": doc.get("title", ""), "tabCount": len(tabs), "tabs": tabs})
    return 0


def cmd_drive_search(client: GoogleWorkspaceClient, args: argparse.Namespace) -> int:
    service = client.service("drive", "v3")
    query = build_drive_query(args.query, full_text=args.full_text)
    if args.modified_after:
        date = args.modified_after
        if "T" not in date:
            date = f"{date}T00:00:00Z"
        query += f" and modifiedTime > '{date}'"
    if args.mime_type:
        query += f" and mimeType = '{args.mime_type}'"

    result = (
        service.files()
        .list(
            q=query,
            pageSize=args.max_results,
            fields="files(id, name, mimeType, webViewLink, modifiedTime)",
            supportsAllDrives=True,
            includeItemsFromAllDrives=True,
        )
        .execute()
    )
    files = result.get("files", [])
    emit_json(
        {
            "count": len(files),
            "files": [
                {
                    "id": item["id"],
                    "name": item["name"],
                    "mimeType": item.get("mimeType", ""),
                    "webViewLink": item.get("webViewLink", ""),
                    "modifiedTime": item.get("modifiedTime", ""),
                }
                for item in files
            ],
        }
    )
    return 0


def get_credentials(interactive: bool = False) -> Credentials:
    config = load_config()
    client_secret_file = Path(config["client_secret_file"]).expanduser()
    token_file = Path(config["token_file"]).expanduser()
    credentials = None

    if token_file.exists():
        credentials = Credentials.from_authorized_user_file(str(token_file), SCOPES)

    if credentials and credentials.valid:
        return credentials

    if credentials and credentials.expired and credentials.refresh_token:
        credentials.refresh(Request())
        write_token(token_file, credentials)
        return credentials

    if not interactive:
        raise GoogleWorkspaceSetupError(
            f"Google Workspace token is missing or invalid. Run: uv run scripts/google-workspace-cli auth login"
        )

    if not client_secret_file.exists():
        raise GoogleWorkspaceSetupError(f"Google OAuth client secret file not found: {client_secret_file}")

    flow = InstalledAppFlow.from_client_secrets_file(str(client_secret_file), SCOPES)
    credentials = flow.run_local_server(port=0)
    write_token(token_file, credentials)
    return credentials


def write_token(path: Path, credentials: Credentials) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.parent.chmod(0o700)
    path.write_text(credentials.to_json(), encoding="utf-8")
    path.chmod(0o600)


def load_config() -> dict[str, str | None]:
    config: dict[str, str | None] = {
        "client_secret_file": str(DEFAULT_CLIENT_SECRET_FILE),
        "token_file": str(DEFAULT_TOKEN_FILE),
        "email": None,
    }

    if LEGACY_RC_FILE.exists():
        parser = configparser.ConfigParser()
        parser.read(LEGACY_RC_FILE)
        if parser.has_section("google"):
            if parser.has_option("google", "credentials_file"):
                config["client_secret_file"] = parser.get("google", "credentials_file")
            if parser.has_option("google", "token_file"):
                config["token_file"] = parser.get("google", "token_file")
            if parser.has_option("google", "email"):
                config["email"] = parser.get("google", "email")

    env_map = {
        "GOOGLE_WORKSPACE_CLIENT_SECRET_FILE": "client_secret_file",
        "GOOGLE_WORKSPACE_TOKEN_FILE": "token_file",
        "GOOGLE_WORKSPACE_EMAIL": "email",
        "GOOGLE_CREDENTIALS_FILE": "client_secret_file",
        "GOOGLE_TOKEN_FILE": "token_file",
        "GOOGLE_EMAIL": "email",
    }
    for env_key, config_key in env_map.items():
        if os.environ.get(env_key):
            config[config_key] = os.environ[env_key]

    return config


def load_env_files(paths: list[Path]) -> None:
    for path in paths:
        if path.exists():
            load_env_file(path)


def load_env_file(path: Path) -> None:
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("export "):
            line = line[len("export ") :].strip()

        key, separator, value = line.partition("=")
        if not separator:
            continue
        key = key.strip()
        if key and key not in os.environ:
            os.environ[key] = strip_env_quotes(value.strip())


def strip_env_quotes(value: str) -> str:
    if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
        return value[1:-1]
    return value


def build_google_workspace_setup_text() -> str:
    return f"""Google Workspace access is not set up for google-workspace-cli.

This CLI uses a local OAuth client secret and stores the user token outside the
repository. It currently supports read-oriented Google Calendar, Docs, and Drive
workflows.

1. Create a Google Cloud OAuth client:

{build_google_workspace_oauth_note_text().rstrip()}

2. Enable these OAuth scopes:

{build_google_workspace_scopes_text().rstrip()}

3. Store the client secret and local config:

{build_google_workspace_env_setup_text().rstrip()}

4. Run browser login:

```sh
uv run scripts/google-workspace-cli auth login
```

Then verify access:

```sh
uv run scripts/google-workspace-cli me
uv run scripts/google-workspace-cli config
```

Reference docs:
- Google Auth for installed apps: https://developers.google.com/identity/protocols/oauth2/native-app
- Calendar API: https://developers.google.com/calendar/api
- Google Docs API: https://developers.google.com/docs/api
- Google Drive API: https://developers.google.com/drive/api
"""


def build_google_workspace_env_setup_text() -> str:
    return """Create the local credential directory:

```sh
mkdir -p ~/.google-workspace
chmod 700 ~/.google-workspace
```

Save the downloaded OAuth client JSON as:

```sh
~/.google-workspace/client_secret.json
```

Optional env file:

```sh
$EDITOR ~/.google-workspace/env
chmod 600 ~/.google-workspace/env
```

Example ~/.google-workspace/env:

```sh
GOOGLE_WORKSPACE_CLIENT_SECRET_FILE=~/.google-workspace/client_secret.json
GOOGLE_WORKSPACE_TOKEN_FILE=~/.google-workspace/token.json
GOOGLE_WORKSPACE_EMAIL=you@example.com
```
"""


def build_google_workspace_scopes_text() -> str:
    lines = "\n".join(f"- {scope}" for scope in SCOPES)
    return f"""The CLI requests these read-only scopes:

{lines}

If the scope list changes later, delete the old token file and run `auth login`
again so Google grants a token with the updated scope set."""


def build_google_workspace_oauth_note_text() -> str:
    return """In Google Cloud Console:

- Create or select a project.
- Enable the Google Calendar API, Google Docs API, and Google Drive API.
- Configure the OAuth consent screen for your account or organization.
- Create an OAuth client ID with application type "Desktop app".
- Download the client JSON file."""


def read_json_arg(value: str) -> Any:
    if value == "-":
        return json.loads(sys.stdin.read())
    if value.startswith("@"):
        return json.loads(Path(value[1:]).expanduser().read_text(encoding="utf-8"))
    return json.loads(value)


def parse_pairs(pairs: list[str]) -> dict[str, str]:
    parsed = {}
    for pair in pairs:
        key, separator, value = pair.partition("=")
        if not separator:
            raise ValueError(f"Invalid query parameter {pair!r}; expected key=value.")
        parsed[key] = value
    return parsed


def api_url(path: str, base: str, pairs: list[str]) -> str:
    if path.startswith("http://") or path.startswith("https://"):
        url = path
    else:
        url = f"{API_BASES[base].rstrip('/')}/{path.lstrip('/')}"
    query = parse_pairs(pairs)
    if query:
        separator = "&" if "?" in url else "?"
        url = f"{url}{separator}{urllib.parse.urlencode(query)}"
    return url


def token_summary(credentials: Credentials) -> dict[str, Any]:
    expiry = credentials.expiry.isoformat() if credentials.expiry else None
    return {
        "valid": credentials.valid,
        "expired": credentials.expired,
        "has_refresh_token": bool(credentials.refresh_token),
        "expiry": expiry,
        "scopes": sorted(credentials.scopes or []),
    }


def calendar_event_summary(event: dict[str, Any], detailed: bool = False) -> dict[str, Any]:
    data: dict[str, Any] = {
        "id": event["id"],
        "summary": event.get("summary", "No title"),
        "start": event["start"].get("dateTime", event["start"].get("date")),
        "end": event["end"].get("dateTime", event["end"].get("date")),
    }
    if detailed:
        data["description"] = event.get("description", "")
        data["location"] = event.get("location", "")
        data["attendees"] = [
            {"email": attendee.get("email"), "responseStatus": attendee.get("responseStatus")}
            for attendee in event.get("attendees", [])
        ]
        data["attachments"] = [
            {
                "title": attachment.get("title", ""),
                "fileUrl": attachment.get("fileUrl", ""),
                "fileId": attachment.get("fileId", ""),
                "mimeType": attachment.get("mimeType", ""),
            }
            for attachment in event.get("attachments", [])
        ]
    return data


def document_text(doc: dict[str, Any], args: argparse.Namespace) -> str:
    tabs = doc.get("tabs", [])
    target_tab = find_target_tab(tabs, args.tab_id, args.tab_title)
    content: list[str] = []

    if target_tab:
        content.extend(tab_text(target_tab))
    elif tabs:
        for tab in tabs:
            properties = tab.get("tabProperties", {})
            content.append(f"\n=== Tab: {properties.get('title', 'Untitled')} (ID: {properties.get('tabId', '')}) ===\n")
            content.extend(tab_text(tab))
    else:
        content.extend(body_text(doc.get("body", {}).get("content", [])))

    return "\n\n".join(item for item in content if item.strip())


def find_target_tab(tabs: list[dict[str, Any]], tab_id: str | None, tab_title: str | None) -> dict[str, Any] | None:
    if tab_id:
        for tab in tabs:
            if tab.get("tabProperties", {}).get("tabId") == tab_id:
                return tab
        raise ValueError(f"Tab ID not found: {tab_id}")
    if tab_title:
        wanted = tab_title.lower()
        for tab in tabs:
            title = tab.get("tabProperties", {}).get("title", "").lower()
            if wanted in title or title in wanted:
                return tab
        raise ValueError(f"Tab title not found: {tab_title}")
    return None


def tab_text(tab: dict[str, Any]) -> list[str]:
    return body_text(tab.get("documentTab", {}).get("body", {}).get("content", []))


def body_text(content: list[dict[str, Any]]) -> list[str]:
    out = []
    for element in content:
        paragraph = element.get("paragraph")
        if not paragraph:
            continue
        text = "".join(item.get("textRun", {}).get("content", "") for item in paragraph.get("elements", []))
        if text.strip():
            out.append(text.strip())
    return out


RAW_QUERY_KEYWORDS = ("contains", " = ", "mimeType", " and ", " or ", "trashed", "fullText")


def build_drive_query(raw: str, full_text: bool = False) -> str:
    if any(keyword in raw for keyword in RAW_QUERY_KEYWORDS):
        return raw
    escaped = raw.replace("'", "\\'")
    if full_text:
        return f"fullText contains '{escaped}'"
    return f"name contains '{escaped}'"


def parse_google_file_id(value: str) -> str:
    parsed = urllib.parse.urlparse(value)
    if parsed.query:
        query = urllib.parse.parse_qs(parsed.query)
        if query.get("id"):
            return query["id"][0]
    parts = [part for part in parsed.path.split("/") if part]
    if "d" in parts:
        index = parts.index("d")
        if index + 1 < len(parts):
            return parts[index + 1]
    return value


def emit_json(value: Any) -> None:
    if OUTPUT_FORMAT == "json":
        payload = {
            "status": "success",
            "metadata": {"execution_time_ms": elapsed_ms(), "records_processed": count_records(value)},
            "data": value,
        }
        print(json.dumps(payload, indent=2, ensure_ascii=False), flush=True)
    else:
        print(json.dumps(value, indent=2, ensure_ascii=False), flush=True)


def emit_error(code: str, message: str, exit_code: int, *, retryable: bool = False, setup_text: str | None = None) -> int:
    if setup_text:
        print(setup_text, file=sys.stderr, flush=True)
    if OUTPUT_FORMAT == "json":
        payload = {
            "status": "error",
            "metadata": {"execution_time_ms": elapsed_ms()},
            "error": {"code": code, "message": message, "retryable": retryable},
        }
        print(json.dumps(payload, indent=2, ensure_ascii=False), flush=True)
    else:
        print(message, file=sys.stderr, flush=True)
    return exit_code


def elapsed_ms() -> int:
    return int((time.perf_counter() - STARTED_AT) * 1000)


def count_records(value: Any) -> int:
    if isinstance(value, list):
        return len(value)
    if isinstance(value, dict):
        for key in ("events", "files", "tabs", "items", "data"):
            item = value.get(key)
            if isinstance(item, list):
                return len(item)
        return 1
    return 1 if value is not None else 0


def build_schema() -> dict[str, Any]:
    return {
        "tool": "google-workspace-cli",
        "output": {
            "formats": ["human", "json"],
            "default": "human",
            "json_envelope": {"status": "success|error", "metadata": "object", "data": "any", "error": "object"},
        },
        "credentials": {
            "env_files": [str(path) for path in GOOGLE_WORKSPACE_ENV_FILES],
            "token_env_vars": ["GOOGLE_WORKSPACE_CLIENT_SECRET_FILE", "GOOGLE_WORKSPACE_TOKEN_FILE", "GOOGLE_WORKSPACE_EMAIL"],
            "legacy": ["GOOGLE_CREDENTIALS_FILE", "GOOGLE_TOKEN_FILE", "GOOGLE_EMAIL", str(LEGACY_RC_FILE)],
        },
        "exit_codes": {
            "0": "success",
            "1": "runtime/API/network/fatal error",
            "2": "CLI syntax or argument error",
            "3": "missing or invalid credentials",
            "4": "permission denied or insufficient scopes",
            "5": "validation, not found, conflict, or domain-specific failure",
        },
        "commands": {
            "setup": {"auth": False, "args": ["--env-only", "--scopes-only", "--oauth-note"]},
            "auth": {"auth": False, "subcommands": ["login", "status"]},
            "me": {"auth": True},
            "config": {"auth": False},
            "api": {"auth": True, "args": ["method", "path", "--base", "--data", "--query"]},
            "calendar": {"auth": True, "subcommands": ["list-events", "get-event"]},
            "docs": {"auth": True, "subcommands": ["get-content", "list-tabs"]},
            "drive": {"auth": True, "subcommands": ["search"]},
        },
    }


if __name__ == "__main__":
    raise SystemExit(main())
